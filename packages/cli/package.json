{
  "name": "@kanban-reloaded/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "kanban-reloaded": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@kanban-reloaded/core": "workspace:*",
    "@kanban-reloaded/server": "workspace:*"
  }
}
